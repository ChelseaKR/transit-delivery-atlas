{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "Transit Delivery Atlas static hosting in AWS. Deploy this stack in us-east-1 so the DNS-validated ACM certificate can be used by CloudFront. The production Route 53 alias is intentionally managed as a separate cutover.",
  "Parameters": {
    "DomainName": {
      "Type": "String",
      "Default": "transit.chelseakr.com",
      "Description": "Public hostname to place on the CloudFront distribution and ACM certificate."
    },
    "HostedZoneId": {
      "Type": "AWS::Route53::HostedZone::Id",
      "Default": "Z09063681IX9IVZF7L6YB",
      "Description": "Route 53 public hosted zone used only for ACM DNS validation. This template does not create the production traffic alias."
    }
  },
  "Resources": {
    "SiteBucket": {
      "Type": "AWS::S3::Bucket",
      "DeletionPolicy": "Retain",
      "UpdateReplacePolicy": "Retain",
      "Properties": {
        "BucketEncryption": {
          "ServerSideEncryptionConfiguration": [
            {
              "ServerSideEncryptionByDefault": {
                "SSEAlgorithm": "AES256"
              }
            }
          ]
        },
        "LifecycleConfiguration": {
          "Rules": [
            {
              "AbortIncompleteMultipartUpload": {
                "DaysAfterInitiation": 7
              },
              "Id": "abort-incomplete-multipart-uploads",
              "Status": "Enabled"
            },
            {
              "Id": "expire-noncurrent-versions",
              "NoncurrentVersionExpiration": {
                "NoncurrentDays": 30
              },
              "Status": "Enabled"
            }
          ]
        },
        "OwnershipControls": {
          "Rules": [
            {
              "ObjectOwnership": "BucketOwnerEnforced"
            }
          ]
        },
        "PublicAccessBlockConfiguration": {
          "BlockPublicAcls": true,
          "BlockPublicPolicy": true,
          "IgnorePublicAcls": true,
          "RestrictPublicBuckets": true
        },
        "Tags": [
          {
            "Key": "Project",
            "Value": "transit-delivery-atlas"
          },
          {
            "Key": "Environment",
            "Value": "production"
          }
        ],
        "VersioningConfiguration": {
          "Status": "Enabled"
        }
      }
    },
    "OriginAccessControl": {
      "Type": "AWS::CloudFront::OriginAccessControl",
      "Properties": {
        "OriginAccessControlConfig": {
          "Description": "SigV4 access from the Transit Delivery Atlas CloudFront distribution to its private S3 origin.",
          "Name": {
            "Fn::Sub": "transit-delivery-atlas-${AWS::AccountId}-oac"
          },
          "OriginAccessControlOriginType": "s3",
          "SigningBehavior": "always",
          "SigningProtocol": "sigv4"
        }
      }
    },
    "CleanRouteFunction": {
      "Type": "AWS::CloudFront::Function",
      "Properties": {
        "AutoPublish": true,
        "FunctionCode": "function handler(event) {\n  var request = event.request;\n  var uri = request.uri;\n\n  if (uri.endsWith('/')) {\n    request.uri = uri + 'index.html';\n  } else if (!uri.includes('.')) {\n    request.uri = uri + '/index.html';\n  }\n\n  return request;\n}\n",
        "FunctionConfig": {
          "Comment": "Resolve clean and directory routes to their statically exported index.html files.",
          "Runtime": "cloudfront-js-2.0"
        },
        "Name": {
          "Fn::Sub": "transit-delivery-atlas-${AWS::AccountId}-routes"
        }
      }
    },
    "SecurityHeadersPolicy": {
      "Type": "AWS::CloudFront::ResponseHeadersPolicy",
      "Properties": {
        "ResponseHeadersPolicyConfig": {
          "Comment": "Enforced security headers for Transit Delivery Atlas, including the existing application CSP and HSTS.",
          "CustomHeadersConfig": {
            "Items": [
              {
                "Header": "Permissions-Policy",
                "Override": true,
                "Value": "camera=(), geolocation=(), microphone=()"
              }
            ]
          },
          "Name": {
            "Fn::Sub": "transit-delivery-atlas-${AWS::AccountId}-security"
          },
          "SecurityHeadersConfig": {
            "ContentSecurityPolicy": {
              "ContentSecurityPolicy": "default-src 'self'; base-uri 'self'; connect-src 'self'; font-src 'self' data:; form-action 'self'; frame-ancestors 'none'; img-src 'self' data:; object-src 'none'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'",
              "Override": true
            },
            "ContentTypeOptions": {
              "Override": true
            },
            "FrameOptions": {
              "FrameOption": "DENY",
              "Override": true
            },
            "ReferrerPolicy": {
              "Override": true,
              "ReferrerPolicy": "strict-origin-when-cross-origin"
            },
            "StrictTransportSecurity": {
              "AccessControlMaxAgeSec": 63072000,
              "IncludeSubdomains": true,
              "Override": true,
              "Preload": true
            }
          }
        }
      }
    },
    "SiteCertificate": {
      "Type": "AWS::CertificateManager::Certificate",
      "Properties": {
        "DomainName": {
          "Ref": "DomainName"
        },
        "DomainValidationOptions": [
          {
            "DomainName": {
              "Ref": "DomainName"
            },
            "HostedZoneId": {
              "Ref": "HostedZoneId"
            }
          }
        ],
        "Tags": [
          {
            "Key": "Project",
            "Value": "transit-delivery-atlas"
          },
          {
            "Key": "Environment",
            "Value": "production"
          }
        ],
        "ValidationMethod": "DNS"
      }
    },
    "Distribution": {
      "Type": "AWS::CloudFront::Distribution",
      "Properties": {
        "DistributionConfig": {
          "Aliases": [
            {
              "Ref": "DomainName"
            }
          ],
          "Comment": "Transit Delivery Atlas production static site",
          "CustomErrorResponses": [
            {
              "ErrorCachingMinTTL": 0,
              "ErrorCode": 403,
              "ResponseCode": 404,
              "ResponsePagePath": "/404.html"
            },
            {
              "ErrorCachingMinTTL": 0,
              "ErrorCode": 404,
              "ResponseCode": 404,
              "ResponsePagePath": "/404.html"
            }
          ],
          "DefaultCacheBehavior": {
            "AllowedMethods": [
              "GET",
              "HEAD"
            ],
            "CachePolicyId": "658327ea-f89d-4fab-a63d-7e88639e58f6",
            "CachedMethods": [
              "GET",
              "HEAD"
            ],
            "Compress": true,
            "FunctionAssociations": [
              {
                "EventType": "viewer-request",
                "FunctionARN": {
                  "Fn::GetAtt": [
                    "CleanRouteFunction",
                    "FunctionARN"
                  ]
                }
              }
            ],
            "ResponseHeadersPolicyId": {
              "Ref": "SecurityHeadersPolicy"
            },
            "TargetOriginId": "SiteBucketOrigin",
            "ViewerProtocolPolicy": "redirect-to-https"
          },
          "DefaultRootObject": "index.html",
          "Enabled": true,
          "HttpVersion": "http2and3",
          "IPV6Enabled": true,
          "Origins": [
            {
              "DomainName": {
                "Fn::GetAtt": [
                  "SiteBucket",
                  "RegionalDomainName"
                ]
              },
              "Id": "SiteBucketOrigin",
              "OriginAccessControlId": {
                "Ref": "OriginAccessControl"
              },
              "S3OriginConfig": {
                "OriginAccessIdentity": ""
              }
            }
          ],
          "PriceClass": "PriceClass_100",
          "Restrictions": {
            "GeoRestriction": {
              "RestrictionType": "none"
            }
          },
          "ViewerCertificate": {
            "AcmCertificateArn": {
              "Ref": "SiteCertificate"
            },
            "MinimumProtocolVersion": "TLSv1.2_2021",
            "SslSupportMethod": "sni-only"
          }
        },
        "Tags": [
          {
            "Key": "Project",
            "Value": "transit-delivery-atlas"
          },
          {
            "Key": "Environment",
            "Value": "production"
          }
        ]
      }
    },
    "SiteBucketPolicy": {
      "Type": "AWS::S3::BucketPolicy",
      "Properties": {
        "Bucket": {
          "Ref": "SiteBucket"
        },
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Sid": "DenyInsecureTransport",
              "Effect": "Deny",
              "Principal": "*",
              "Action": "s3:*",
              "Resource": [
                {
                  "Fn::GetAtt": [
                    "SiteBucket",
                    "Arn"
                  ]
                },
                {
                  "Fn::Sub": "${SiteBucket.Arn}/*"
                }
              ],
              "Condition": {
                "Bool": {
                  "aws:SecureTransport": "false"
                }
              }
            },
            {
              "Sid": "AllowCloudFrontReadOnly",
              "Effect": "Allow",
              "Principal": {
                "Service": "cloudfront.amazonaws.com"
              },
              "Action": "s3:GetObject",
              "Resource": {
                "Fn::Sub": "${SiteBucket.Arn}/*"
              },
              "Condition": {
                "StringEquals": {
                  "AWS:SourceArn": {
                    "Fn::Sub": "arn:${AWS::Partition}:cloudfront::${AWS::AccountId}:distribution/${Distribution}"
                  }
                }
              }
            }
          ]
        }
      }
    },
    "GitHubDeployRole": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Federated": {
                  "Fn::Sub": "arn:${AWS::Partition}:iam::${AWS::AccountId}:oidc-provider/token.actions.githubusercontent.com"
                }
              },
              "Action": "sts:AssumeRoleWithWebIdentity",
              "Condition": {
                "StringEquals": {
                  "token.actions.githubusercontent.com:aud": "sts.amazonaws.com",
                  "token.actions.githubusercontent.com:sub": "repo:ChelseaKR/transit-delivery-atlas:environment:production"
                }
              }
            }
          ]
        },
        "Description": "Least-privilege GitHub Actions deployment role for the Transit Delivery Atlas production environment.",
        "MaxSessionDuration": 3600,
        "Policies": [
          {
            "PolicyName": "transit-delivery-atlas-static-deploy",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Sid": "ListSiteBucket",
                  "Effect": "Allow",
                  "Action": [
                    "s3:GetBucketLocation",
                    "s3:ListBucket"
                  ],
                  "Resource": {
                    "Fn::GetAtt": [
                      "SiteBucket",
                      "Arn"
                    ]
                  }
                },
                {
                  "Sid": "WriteSiteObjects",
                  "Effect": "Allow",
                  "Action": [
                    "s3:DeleteObject",
                    "s3:GetObject",
                    "s3:PutObject"
                  ],
                  "Resource": {
                    "Fn::Sub": "${SiteBucket.Arn}/*"
                  }
                },
                {
                  "Sid": "InvalidateDistribution",
                  "Effect": "Allow",
                  "Action": [
                    "cloudfront:CreateInvalidation",
                    "cloudfront:GetInvalidation"
                  ],
                  "Resource": {
                    "Fn::Sub": "arn:${AWS::Partition}:cloudfront::${AWS::AccountId}:distribution/${Distribution}"
                  }
                }
              ]
            }
          }
        ],
        "Tags": [
          {
            "Key": "Project",
            "Value": "transit-delivery-atlas"
          },
          {
            "Key": "Environment",
            "Value": "production"
          }
        ]
      }
    }
  },
  "Outputs": {
    "SiteBucketName": {
      "Description": "Private S3 bucket that receives the static export.",
      "Value": {
        "Ref": "SiteBucket"
      }
    },
    "DistributionId": {
      "Description": "CloudFront distribution ID used for deployment invalidations.",
      "Value": {
        "Ref": "Distribution"
      }
    },
    "DistributionDomainName": {
      "Description": "CloudFront hostname for pre-cutover verification.",
      "Value": {
        "Fn::GetAtt": [
          "Distribution",
          "DomainName"
        ]
      }
    },
    "GitHubDeployRoleArn": {
      "Description": "Dedicated role ARN for the GitHub production environment.",
      "Value": {
        "Fn::GetAtt": [
          "GitHubDeployRole",
          "Arn"
        ]
      }
    }
  }
}
