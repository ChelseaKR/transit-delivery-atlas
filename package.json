{
  "name": "transit-delivery-atlas",
  "version": "0.1.0",
  "description": "Independent, source-linked crosswalk of California transit directives, named entities, timing, dependencies, and open questions.",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "npm run data:export && WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "data:validate": "node scripts/validate-data.mjs",
    "data:export": "npm run data:validate && node scripts/export-data.mjs",
    "test": "npm run build && node --test tests/data-integrity.test.mjs tests/rendered-html.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "typecheck": "tsc --noEmit --incremental false",
    "audit:production": "npm audit --omit=dev --audit-level=moderate",
    "check": "npm run lint && npm run typecheck && npm test && npm run audit:production"
  },
  "dependencies": {
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.44.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "22.19.19",
    "@types/react": "^19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitejs/plugin-rsc": "^0.5.27",
    "eslint": "9.39.4",
    "eslint-config-next": "^16.2.10",
    "react-server-dom-webpack": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "typescript": "5.9.3",
    "vinext": "0.2.1",
    "vite": "^8.1.4",
    "wrangler": "^4.110.0"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.10"
    }
  },
  "type": "module"
}
